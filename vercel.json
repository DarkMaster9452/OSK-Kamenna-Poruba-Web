{
	"version": 2,
	"headers": [
		{
			"source": "/sitemap.xml",
			"headers": [
				{
					"key": "Content-Type",
					"value": "application/xml; charset=UTF-8"
				}
			]
		},
		{
			"source": "/assets/images/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		}
	],
	"rewrites": [
		{ "source": "/akademia", "destination": "/pages/akademia.html" },
		{ "source": "/akademia.html", "destination": "/pages/akademia.html" },
		{ "source": "/atim", "destination": "/pages/atim.html" },
		{ "source": "/atim.html", "destination": "/pages/atim.html" },
		{ "source": "/blog", "destination": "/pages/blog.html" },
		{ "source": "/blog.html", "destination": "/pages/blog.html" },
		{ "source": "/blog/:slug", "destination": "/pages/blog_post.html" },
		{ "source": "/galeria", "destination": "/pages/galeria.html" },
		{ "source": "/galeria.html", "destination": "/pages/galeria.html" },
		{ "source": "/important_info", "destination": "/pages/important_info.html" },
		{ "source": "/important_info.html", "destination": "/pages/important_info.html" },
		{ "source": "/matches", "destination": "/pages/matches.html" },
		{ "source": "/matches.html", "destination": "/pages/matches.html" },
		{ "source": "/skupiny", "destination": "/pages/skupiny.html" },
		{ "source": "/skupiny.html", "destination": "/pages/skupiny.html" },
		{ "source": "/tabulka", "destination": "/pages/tabulka.html" },
		{ "source": "/tabulka.html", "destination": "/pages/tabulka.html" },
		{ "source": "/trainings", "destination": "/pages/trainings.html" },
		{ "source": "/trainings.html", "destination": "/pages/trainings.html" },
		{ "source": "/vedenie", "destination": "/pages/vedenie.html" },
		{ "source": "/vedenie.html", "destination": "/pages/vedenie.html" },
		{ "source": "/account_management", "destination": "/pages/account_management.html" },
		{ "source": "/account_management.html", "destination": "/pages/account_management.html" },
		{ "source": "/reset_password", "destination": "/pages/reset_password.html" },
		{ "source": "/reset_password.html", "destination": "/pages/reset_password.html" },
		{ "source": "/player_detail_coach", "destination": "/pages/player_detail_coach.html" },
		{ "source": "/player_detail_coach.html", "destination": "/pages/player_detail_coach.html" },
		{
			"source": "/api/cron-sportnet",
			"destination": "/api/cron-sportnet.js"
		},
		{
			"source": "/api/:path*",
			"destination": "/api/[...all].js"
		}
	]
}