{
	"version": 2,
	"headers": [
		{
			"source": "/sitemap.xml",
			"headers": [
				{
					"key": "Content-Type",
					"value": "application/xml; charset=UTF-8"
				}
			]
		},
		{
			"source": "/assets/images/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		}
	],
	"rewrites": [
		{
			"source": "/account_management.html",
			"destination": "/pages/account_management.html"
		},
		{
			"source": "/akademia.html",
			"destination": "/pages/akademia.html"
		},
		{
			"source": "/atim.html",
			"destination": "/pages/atim.html"
		},
		{
			"source": "/blog.html",
			"destination": "/pages/blog.html"
		},
		{
			"source": "/galeria.html",
			"destination": "/pages/galeria.html"
		},
		{
			"source": "/important_info.html",
			"destination": "/pages/important_info.html"
		},
		{
			"source": "/matches.html",
			"destination": "/pages/matches.html"
		},
		{
			"source": "/player_detail_coach.html",
			"destination": "/pages/player_detail_coach.html"
		},
		{
			"source": "/reset_password.html",
			"destination": "/pages/reset_password.html"
		},
		{
			"source": "/skupiny.html",
			"destination": "/pages/skupiny.html"
		},
		{
			"source": "/tabulka.html",
			"destination": "/pages/tabulka.html"
		},
		{
			"source": "/trainings.html",
			"destination": "/pages/trainings.html"
		},
		{
			"source": "/vedenie.html",
			"destination": "/pages/vedenie.html"
		},
		{
			"source": "/api/cron-sportnet",
			"destination": "/api/cron-sportnet.js"
		},
		{
			"source": "/api/:path*",
			"destination": "/api/[...all].js"
		}
	]
}