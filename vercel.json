{
	"version": 2,
	"headers": [
		{
			"source": "/assets/images/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		}
	],
	"rewrites": [
		{
			"source": "/api/cron-sportnet",
			"destination": "/api/cron-sportnet.js"
		},
		{
			"source": "/api/:path*",
			"destination": "/api/[...all].js"
		}
	],
	"crons": [
		{
			"path": "/api/cron-sportnet",
			"schedule": "*/10 * * * *"
		}
	]
}