NODE_ENV=development
PORT=4000
TRUST_PROXY=false

# Required: Neon PostgreSQL connection string
DATABASE_URL=

# Frontend URL(s) for CORS (comma-separated)
# Production example: https://your-app.vercel.app,https://*.vercel.app
FRONTEND_ORIGIN=http://127.0.0.1:5500,http://localhost:5500,http://127.0.0.1:5501,http://localhost:5501

# Use a long random secret in production
JWT_ACCESS_SECRET=change_this_to_long_random_value
JWT_ACCESS_EXPIRES=15m

# Cookie settings
COOKIE_NAME=osk_session
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_DOMAIN=
COOKIE_MAX_AGE_MS=2592000000

# Optional extra CSRF guard for write requests
CSRF_PROTECTION=true

# Email notifications for new trainings (optional)
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=OŠK Kamenná Poruba
CONTACT_FORM_TO_EMAIL=

# Sportsnet API integration (optional)
# Preferred variable names (current Sportnet API):
# API key sa posiela iba cez HTTP hlavičku: Authorization: ApiKey {apikey}
# Nevkladaj API kľúč do URL (SPORTNET_API_URL / SPORTSNET_API_BASE query parametrov)
SPORTNET_API_BASE=
SPORTNET_ORG_ID=54b532721c6198f161840003
# AppSpace slug for the club's public teams/squad API (sutaze.api.sportnet.online)
# Check /api/sportsnet/players/debug to verify. Default: osk-kamenna-poruba.futbalnet.sk
SPORTNET_APP_SPACE=
SPORTNET_MATCHES_PATH=/organizations/{orgId}/matches
SPORTNET_API_URL=
SPORTNET_API_KEY=

# Backward-compatible aliases:
SPORTSNET_API_URL=
SPORTSNET_API_KEY=
SPORTSNET_TEAM_ID=
SPORTSNET_COMPETITION_ID=
SPORTSNET_SEASON=
# Cache TTL in seconds (default: 14400 = 4 hours).
# Data is fetched from SportNet at most once per this interval.
SPORTNET_PLAYERS_CACHE_SECONDS=14400
SPORTSNET_CACHE_SECONDS=14400

# Optional: override the directory where SportNet cache files are stored.
# On Vercel /tmp is the only writable location and is used automatically.
SPORTNET_CACHE_DIR=

# Optional: secret token for the /api/cron-sportnet endpoint.
# Set this in Vercel env vars so only Vercel cron can trigger it.
CRON_SECRET=

# Instagram feed integration (optional)
# Requires long-lived Instagram Graph API token.
INSTAGRAM_ACCESS_TOKEN=
# 'me' usually works with user token; keep unless provider requires explicit ID.
INSTAGRAM_USER_ID=me
# Number of posts loaded into gallery.
INSTAGRAM_FEED_LIMIT=8
# Feed cache TTL in seconds.
INSTAGRAM_CACHE_SECONDS=300